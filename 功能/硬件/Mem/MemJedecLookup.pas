function MemJedecNormalizeId(AId: Word): Word;
var
  hi, lo: Byte;
begin
  hi := AId shr 8;
  lo := AId and $FF;
  if lo = $7F then
    Result := Word(1 shl 8) or (hi and $7F)
  else if hi = 0 then
  begin
    if lo >= $80 then
      Result := lo and $7F
    else
      Result := AId;
  end
  else
    Result := Word(hi shl 8) or (lo and $7F);
end;

function MemJedecManufacturerText(AId: Word): string;
var
  norm: Word;
  bank, code: Byte;
begin
  norm := MemJedecNormalizeId(AId);
  bank := norm shr 8;
  code := norm and $7F;
  case bank of
    0: Result := MemJedecBank0(code);
    1: Result := MemJedecBank1(code);
    2: Result := MemJedecBank2(code);
    3: Result := MemJedecBank3(code);
    4: Result := MemJedecBank4(code);
