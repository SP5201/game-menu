<?xml version="1.0" encoding="UTF-8"?>
<!--炫彩界面库-窗口布局文件-->
<head>
	<bindJsFile value="" />
</head>
<windowUI rect="20,20,480,360" windowType="modalWindow" windowStyle="20" center="true" minSize="400,280" maxWindow="false">
	<layoutEleUI rect="8,30,440,300" layout.width="fill" layout.height="fill" layout.space="10" padding="4,0,4,0">
		<layoutEleUI rect="0,0,100,38" layout.width="fill" layout.height="38" layout.horizon="true" layout.alignV="center" layout.space="8" expandT="false">
			<layoutEleUI rect="0,0,100,36" layout.width=":1" layout.height="fill" layout.horizon="true" layout.alignV="center" layout.space="4" expandT="false">
				<shapePicture name="pic_feedback_dialog_logo" rect="0,0,20,20" layout.width="20" layout.height="20" expandT="false" />
				<shapeText name="txt_feedback_title" rect="0,0,100,28" layout.width=":1" layout.height="fill" content="反馈" />
			</layoutEleUI>
			<buttonUI name="btn_feedback_close" rect="0,0,60,25" layout.width="20" layout.height="20" buttonType="close" />
		</layoutEleUI>
		<editUI name="edit_feedback_content" rect="0,0,100,180" layout.width="fill" layout.height=":1" multiLine="true" edit.autoWrap="true" contentTips="请描述问题现象、复现步骤，或写下你的建议…" />
