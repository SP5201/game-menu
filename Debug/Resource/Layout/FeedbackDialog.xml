		<layoutEleUI rect="0,0,100,48" layout.width="fill" layout.height="48" layout.horizon="true" layout.alignH="right" layout.space="10" layout.alignV="center" padding="0,6,0,0">
			<buttonUI name="btn_feedback_cancel" rect="0,0,96,34" layout.width="90" layout.height="30" content="取消" />
			<buttonUI name="btn_feedback_send" rect="0,0,96,34" layout.width="110" layout.height="30" content="提交 Issue" />
		</layoutEleUI>
	</layoutEleUI>
</windowUI>
